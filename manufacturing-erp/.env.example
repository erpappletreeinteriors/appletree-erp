# Used by docker-compose.yml to configure the Postgres container and pass
# secrets through to the backend service. Copy to .env and fill in real
# secrets before running `docker compose up`.

POSTGRES_USER=appletree
POSTGRES_PASSWORD=appletree_dev_password
POSTGRES_DB=appletree_manufacturing

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

CORS_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=http://localhost:3000
