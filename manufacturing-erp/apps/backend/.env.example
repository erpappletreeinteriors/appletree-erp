# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://appletree:appletree_dev_password@localhost:5432/appletree_manufacturing?schema=public

# Auth
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
PASSWORD_RESET_TOKEN_TTL_MS=3600000
OAUTH_TICKET_TTL_MS=60000

# CORS / frontend
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Google OAuth — create an OAuth client at https://console.cloud.google.com/apis/credentials
# (Authorized redirect URI must exactly match GOOGLE_CALLBACK_URL). Google Sign-In is
# disabled in practice (clicking it will fail) until these are set to real values.
GOOGLE_CLIENT_ID=not-configured
GOOGLE_CLIENT_SECRET=not-configured
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Seed (used only by prisma/seed.ts on first run)
SEED_ADMIN_EMAIL=sales.appletreeinteriors@gmail.com
SEED_ADMIN_PASSWORD=change-me-on-first-login
