# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://appletree:appletree_dev_password@localhost:5432/appletree_manufacturing?schema=public

# Auth
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# CORS
CORS_ORIGIN=http://localhost:5173

# Seed (used only by prisma/seed.ts on first run)
SEED_ADMIN_EMAIL=sales.appletreeinteriors@gmail.com
SEED_ADMIN_PASSWORD=change-me-on-first-login
